{
  "name": "fuzitter",
  "version": "0.1.0",
  "description": "Moodle-integrated desktop workspace for local file organization",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "build": "electron-packager . Fuzitter --platform=win32 --arch=x64 --out=dist --overwrite --icon=assets/fuzitter.ico --ignore=tmp_i2_review",
    "build:local": "electron-packager . Fuzitter --platform=win32 --arch=x64 --out=local-dist --overwrite --icon=assets/fuzitter.ico --ignore=tmp_i2_review"
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12"
  }
}
